{
	"schema_version": 1,
	"quilt_loader": {
		"group": "${group}",
		"id": "conditionaltargeting",
		"version": "${version}",
		"metadata": {
			"name": "Conditional Targeting",
			"description": "A library mod that allows better targeting of entities via breaking down target selection into many mini selectors.\nI'm making this mod as most of my mods will need this because im not great at making these systems.",
			"contributors": {
				"Ubunifu": "Owner"
			},
			"contact": {
				"homepage": "https://example.com/",
				"issues": "https://github.com/QuiltMC/quilt-template-mod/issues",
				"sources": "https://github.com/QuiltMC/quilt-template-mod"
			},
			"icon": "assets/conditionaltargeting/icon.png"
		},
		"intermediate_mappings": "net.fabricmc:intermediary",
		"entrypoints": {
			"init": "com.ubunifu.conditionaltargeting.ConditionalTargetingMod"
		},
		"depends": [
			{
				"id": "quilt_loader",
				"versions": ">=0.19.1"
			},
			{
				"id": "quilted_fabric_api",
				"versions": ">=7.0.2"
			},
			{
				"id": "minecraft",
				"versions": ">=1.20"
			}
		]
	},
	"mixin": "conditionaltargeting.mixins.json"
}
